DATABASE_URL=postgresql://user:password@localhost:5432/kamlesh_paints
JWT_SECRET=your_jwt_secret_minimum_32_characters
JWT_ALGORITHM=HS256

# Payments (Razorpay) — optional; checkout runs in mock mode until set
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Image hosting (Cloudinary) — optional; uploads save locally to /uploads until set
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# AI (Google Gemini) — optional; AI Studio uses mock answers until set
GEMINI_API_KEY=your_gemini_api_key

# Email notifications (SMTP) — optional; enquiries/orders log to stdout until set
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=your_from_address
NOTIFY_EMAIL=kamlesh6678@gmail.com

# Public base URL of this API (used for locally-uploaded image URLs)
PUBLIC_BASE_URL=http://localhost:8000
